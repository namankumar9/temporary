    {
      "action": "deny",
      "process": "any",
      "remote-hosts": "ads.example.com",
      "ports": "443",
      "protocol": "tcp",
      "direction": "outgoing",
      "notes": "Block ads domain"
    },
    {
      "action": "deny",
      "process": "any",
      "remote-hosts": "dzone.com",
      "ports": "80,443",
      "protocol": "tcp",
      "direction": "outgoing"
    },
    {
      "action": "deny",
      "process": "any",
      "remote-hosts": "baeldung.com",
      "ports": "80,443",
      "protocol": "tcp",
      "direction": "outgoing"
    }
  ]
}
